# TOABH staging env example
# Copy the values you actually use into Vercel/project env or a local .env.staging.local

# Required: enables Neon/Postgres mode
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Required: used in invite/reset links generated by the backend
APP_BASE_URL=https://your-staging-app.example.com

# Leave blank when frontend and API share the same origin/project.
# Set explicitly only when the frontend must call a different backend origin.
VITE_API_URL=

# Optional: only for live smoke scripts, not needed for normal app runtime
TOABH_BASE_URL=https://your-staging-app.example.com
TOABH_SMOKE_USERNAME=boss
TOABH_SMOKE_PASSWORD=Boss@2026!
